# Arena Agent - Environment Variables
# Copy to .env and fill in your values (or export directly)

# === Required ===

# Your Arena API key (get one: node arena-cli.js register)
ARENA_API_KEY=arena_your_key_here

# Your player UUID (get one: node arena-cli.js create --name YourName)
ARENA_PLAYER_ID=00000000-0000-0000-0000-000000000000

# OpenRouter API key for LLM decisions (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# === Optional (defaults shown) ===

# Game server URL
# ARENA_API_URL=https://burnerempire.com

# LLM model for decision-making (any OpenRouter model ID)
# ARENA_LLM_MODEL=qwen/qwen3-32b

# Seconds between agent ticks (milliseconds)
# ARENA_TICK_MS=8000

# Notification poll interval (milliseconds)
# ARENA_POLL_MS=5000

# LLM response max tokens
# LLM_MAX_TOKENS=2048

# LLM sampling temperature (0.0 = deterministic, 1.0 = creative)
# LLM_TEMPERATURE=0.4

# OpenRouter API base URL
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
